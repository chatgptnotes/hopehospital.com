{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "installCommand": "npm install",
  "framework": null,
  "public": false,
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "hopehospital.com" }],
      "destination": "https://www.hopehospital.com/:path*",
      "permanent": true
    },
    { "source": "/neurosurgery", "destination": "/departments/neurosurgery", "statusCode": 301 },
    { "source": "/critical-care", "destination": "/departments/critical-care", "statusCode": 301 },
    { "source": "/health-packages", "destination": "/departments", "statusCode": 301 },
    { "source": "/news", "destination": "/blog", "statusCode": 301 },
    { "source": "/gallbladder-symptoms-surgery-tips-for-avoiding-discomfort", "destination": "/blog", "statusCode": 301 },
    { "source": "/corporate-empanelment-cashless-treatment-facility", "destination": "/empanelments", "statusCode": 301 },
    { "source": "/list-of-empanelments", "destination": "/empanelments", "statusCode": 301 },
    { "source": "/total-knee-joint-replacement-surgery", "destination": "/blog/knee-replacement-surgery-nagpur-guide", "statusCode": 301 }
  ],
  "headers": [
    {
      "source": "/(.+\\.(?:webp|png|jpg|jpeg|gif|svg|ico|woff2|woff))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.+\\.(?:css|js))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://www.google-analytics.com; frame-src https://www.google.com https://maps.google.com"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(self)"
        }
      ]
    }
  ]
}
